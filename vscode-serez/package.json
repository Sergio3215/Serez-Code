{
  "name": "serez-code",
  "displayName": "Serez-Code",
  "description": "Syntax highlighting and formatter for Serez-Code (.sz) files",
  "version": "1.0.0",
  "icon": "icon.png",
  "publisher": "sd-tools",
  "engines": {
    "vscode": "^1.74.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Sergio3215/serez-code"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:serez"
  ],
  "contributes": {
    "languages": [
      {
        "id": "serez",
        "aliases": [
          "Serez-Code",
          "serez"
        ],
        "extensions": [
          ".sz"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "serez",
        "scopeName": "source.serez",
        "path": "./syntaxes/serez.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[serez]": {
        "editor.defaultFormatter": "sergio.serez-code",
        "editor.formatOnSave": true,
        "editor.tabSize": 4,
        "editor.insertSpaces": true
      }
    }
  }
}
