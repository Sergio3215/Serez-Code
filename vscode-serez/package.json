{
  "name": "serez-code-formatter",
  "displayName": "Serez-Code Formatter",
  "description": "Syntax highlighting and formatter for Serez-Code — .sz, .szx (JSX) and .szs (styles)",
  "version": "1.5.0",
  "icon": "icon.png",
  "license": "MIT",
  "publisher": "sd-tools",
  "engines": {
    "vscode": "^1.74.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Sergio3215/serez-code"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:serez-code",
    "onLanguage:serez-code-jsx",
    "onLanguage:serez-style"
  ],
  "contributes": {
    "languages": [
      {
        "id": "serez-code",
        "aliases": [
          "Serez-Code",
          "serez-code-formatter",
          "serez-dev",
          "serezdev"
        ],
        "extensions": [
          ".sz"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "serez-code-jsx",
        "aliases": [
          "Serez-Code JSX",
          "serez-jsx"
        ],
        "extensions": [
          ".szx"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "serez-style",
        "aliases": [
          "Serez Style",
          "serez-szs"
        ],
        "extensions": [
          ".szs"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "serez-code",
        "scopeName": "source.serez",
        "path": "./syntaxes/serez.tmLanguage.json"
      },
      {
        "language": "serez-code-jsx",
        "scopeName": "source.serez.jsx",
        "path": "./syntaxes/serez-jsx.tmLanguage.json"
      },
      {
        "language": "serez-style",
        "scopeName": "source.serez.style",
        "path": "./syntaxes/serez-style.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[serez-code]": {
        "editor.defaultFormatter": "sd-tools.serez-code-formatter",
        "editor.formatOnSave": true,
        "editor.tabSize": 4,
        "editor.insertSpaces": true
      },
      "[serez-code-jsx]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
      },
      "[serez-style]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
      }
    }
  }
}
