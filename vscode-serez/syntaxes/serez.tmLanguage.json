{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Serez-Code",
  "scopeName": "source.serez",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.serez",
          "match": "//.*$"
        },
        {
          "name": "comment.block.serez",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.serez" } },
          "endCaptures": { "0": { "name": "punctuation.definition.comment.serez" } }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.serez",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.serez" } },
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.serez" } },
          "patterns": [
            {
              "name": "constant.character.escape.serez",
              "match": "\\\\[ntr\\\\\"{}]"
            },
            {
              "name": "meta.interpolation.serez",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.serez" } },
              "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.serez" } },
              "contentName": "source.serez.embedded",
              "patterns": [{ "include": "$self" }]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.serez",
          "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "name": "constant.numeric.binary.serez",
          "match": "\\b0[bB][01][01_]*\\b"
        },
        {
          "name": "constant.numeric.decimal.serez",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*\\b"
        },
        {
          "name": "constant.numeric.integer.serez",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.serez",
          "match": "\\b(if|else|while|do|for|in|switch|case|default|break|continue|return|try|catch|finally|throw)\\b"
        },
        {
          "name": "keyword.declaration.serez",
          "match": "\\b(fn|let|const|class|interface|enum|new|is)\\b"
        },
        {
          "name": "keyword.modifier.serez",
          "match": "\\b(public|private|static|abstract|sealed|get|set)\\b"
        },
        {
          "name": "keyword.other.serez",
          "match": "\\b(out|super|this)\\b"
        }
      ]
    },
    "types": {
      "name": "support.type.serez",
      "match": "\\b(int|decimal|string|bool|any|void|null)\\b"
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.serez",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.serez",
          "match": "\\bnull\\b"
        },
        {
          "name": "variable.language.this.serez",
          "match": "\\bthis\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.serez",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.comparison.serez",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.serez",
          "match": "\\*\\*|[+\\-*/%]"
        },
        {
          "name": "keyword.operator.bitwise.serez",
          "match": "&|\\||\\^|~|<<|>>"
        },
        {
          "name": "keyword.operator.assignment.serez",
          "match": "\\+=|-=|\\*=|/=|%=|="
        },
        {
          "name": "keyword.operator.null.serez",
          "match": "\\?\\?|\\?\\."
        },
        {
          "name": "keyword.operator.arrow.serez",
          "match": "=>"
        },
        {
          "name": "keyword.operator.spread.serez",
          "match": "\\.\\.\\."
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.serez",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.serez",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
