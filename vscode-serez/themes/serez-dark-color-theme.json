    "button.foreground": "#ffffff",
    "button.hoverBackground": "#a78bfa",
    "badge.background": "#8b5cf6",
    "badge.foreground": "#ffffff",
    "progressBar.background": "#8b5cf6",
    "peekView.border": "#8b5cf6",
    "peekViewEditor.background": "#0c0c1e",
    "peekViewResult.background": "#0c0c1e",
    "textLink.foreground": "#22d3ee",
    "textLink.activeForeground": "#67e8f9"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#6b6b8a", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted.double.serez", "string.quoted.double.raw.serez"],
      "settings": { "foreground": "#86efac" }
    },
    {
      "scope": ["constant.character.escape", "punctuation.section.interpolation"],
      "settings": { "foreground": "#22d3ee" }
    },
    {
      "scope": ["meta.interpolation.serez"],
      "settings": { "foreground": "#e2e2f0" }
    },
    {
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#fbbf24" }
    },
    {
      "scope": ["constant.language", "constant.language.boolean", "constant.language.null"],
      "settings": { "foreground": "#fb923c" }
    },
    {
      "scope": ["keyword", "keyword.control", "keyword.declaration", "keyword.control.import"],
      "settings": { "foreground": "#a78bfa" }
    },
    {
      "scope": ["keyword.modifier", "storage.modifier"],
      "settings": { "foreground": "#c084fc", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#9aa0c4" }
    },
    {
      "scope": ["keyword.operator.arrow.serez", "keyword.operator.null.serez", "keyword.operator.spread.serez"],
      "settings": { "foreground": "#89ddff" }
    },
    {
      "scope": ["support.type", "storage.type", "support.type.serez"],
      "settings": { "foreground": "#f0abfc" }
    },
    {
      "scope": ["support.class.builtin.serez", "support.class", "support.constant"],
      "settings": { "foreground": "#22d3ee" }
    },
    {
      "scope": ["entity.name.type.class", "entity.name.type", "entity.name.class"],
      "settings": { "foreground": "#f0abfc", "fontStyle": "bold" }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": { "foreground": "#7dd3fc" }
    },
    {
      "scope": ["variable.language.this.serez", "variable.language", "constant.language.this"],
      "settings": { "foreground": "#fb7185", "fontStyle": "italic" }
    },
    {
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#e2e2f0" }
    },
    {
      "scope": ["variable", "variable.other.serez"],
      "settings": { "foreground": "#e2e2f0" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#a78bfa" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#7dd3fc" }
    },
    {
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#8b8bac" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#f87171" }
    }
  ]
}
