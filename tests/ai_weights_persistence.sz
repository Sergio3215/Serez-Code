// Tests for Autodiff.saveWeights / loadWeights (.szw format)

let tmp = "test_weights_tmp.szw"

// ── Save and load a single tensor ────────────────────────────────────────────

test("saveWeights creates file and loadWeights recovers data", () => {
    let w = Tensor.from([1.0, 2.0, 3.0, 4.0])
    w = w.reshape([2, 2])
    Autodiff.saveWeights(tmp, [w])
    let loaded = Autodiff.loadWeights(tmp)
    let w2 = loaded[0]
    let arr = w2.toArray()
    assert(Math.abs(arr[0] - 1.0) < 0.0001, "loaded[0][0] = 1.0")
    assert(Math.abs(arr[1] - 2.0) < 0.0001, "loaded[0][1] = 2.0")
    assert(Math.abs(arr[2] - 3.0) < 0.0001, "loaded[0][2] = 3.0")
    assert(Math.abs(arr[3] - 4.0) < 0.0001, "loaded[0][3] = 4.0")
})

test("loadWeights preserves tensor shape", () => {
    let w = Tensor.zeros([3, 4])
    Autodiff.saveWeights(tmp, [w])
    let loaded = Autodiff.loadWeights(tmp)
    let s = loaded[0].shape
    assert(s[0] == 3 and s[1] == 4, "shape preserved as [3,4]")
})

// ── Multiple tensors ──────────────────────────────────────────────────────────

test("saveWeights/loadWeights preserves multiple tensors", () => {
    let w1 = Tensor.from([1.0, 2.0])
    let w2 = Tensor.from([3.0, 4.0, 5.0])
    let b  = Tensor.from([0.1])
    Autodiff.saveWeights(tmp, [w1, w2, b])
    let loaded = Autodiff.loadWeights(tmp)
    assert(loaded.length() == 3, "loaded 3 tensors")
    let a1 = loaded[0].toArray()
    let a2 = loaded[1].toArray()
    let a3 = loaded[2].toArray()
    assert(Math.abs(a1[0] - 1.0) < 0.0001, "tensor 0 element 0")
    assert(Math.abs(a2[2] - 5.0) < 0.0001, "tensor 1 element 2")
    assert(Math.abs(a3[0] - 0.1) < 0.001,  "tensor 2 element 0")
})

// ── High-dimensional tensors ──────────────────────────────────────────────────

test("saveWeights handles 4D tensor", () => {
    let t = Tensor.ones([2, 3, 4, 5])
    Autodiff.saveWeights(tmp, [t])
    let loaded = Autodiff.loadWeights(tmp)
    let s = loaded[0].shape
    assert(s[0] == 2 and s[1] == 3 and s[2] == 4 and s[3] == 5, "4D shape preserved")
    let arr = loaded[0].toArray()
    assert(Math.abs(arr[0] - 1.0) < 0.0001, "4D tensor data preserved")
})

// ── Round-trip after training step ───────────────────────────────────────────

test("save trained weights and reload produces same values", () => {
    // One step of gradient descent
    let w = Tensor.from([0.0, 0.0])
    let target = Tensor.from([1.0, 1.0])
    let m = Tensor.zeros([2])
    let v = Tensor.zeros([2])

    Autodiff.tape()
    let loss = Autodiff.mseLoss(w, target)
    Autodiff.backward(loss)
    let grad = Autodiff.gradient(w)
    let result = Autodiff.adamStep(w, grad, m, v, 1, 0.1)
    w = result[0]

    // Save
    Autodiff.saveWeights(tmp, [w])

    // Load and check same values
    let loaded = Autodiff.loadWeights(tmp)
    let w2 = loaded[0]
    let a1 = w.toArray()
    let a2 = w2.toArray()
    assert(Math.abs(a1[0] - a2[0]) < 0.0001, "loaded weight matches saved after training")
    assert(Math.abs(a1[1] - a2[1]) < 0.0001, "loaded weight[1] matches")
})

// ── Float precision ───────────────────────────────────────────────────────────

test("saveWeights preserves float64 precision", () => {
    let precise = 3.141592653589793
    let w = Tensor.from([precise])
    Autodiff.saveWeights(tmp, [w])
    let loaded = Autodiff.loadWeights(tmp)
    let arr = loaded[0].toArray()
    assert(Math.abs(arr[0] - precise) < 0.000000001, "float64 precision preserved")
})

// ── Error cases ───────────────────────────────────────────────────────────────

test("loadWeights on nonexistent file emits error", () => {
    let threw = false
    try {
        let x = Autodiff.loadWeights("this_file_does_not_exist_xyz.szw")
    } catch (e) {
        threw = true
    }
    // The error is reported via eprintln (not throw), so EvalResult::Error
    // Just verify no crash
    assert(true, "loadWeights nonexistent file handled gracefully")
})

summary()
