// Unit tests for type sizes.
//
// The old `sizeof(TYPE)` / `sizeof(expr)` operator was removed; byte-sizes of the
// concrete numeric/bool types are now queried with Memory.sizeof("type"), which
// supports "int", "decimal" and "bool". The `sizeof(null)` operator still returns
// 0. (Broader Memory.sizeof coverage lives in unit_memory.)

test("Memory.sizeof int is 8", () => {
    let s = Memory.sizeof("int");
    assert(s == 8, "int should be 8 bytes");
});

test("Memory.sizeof decimal is 8", () => {
    assert(Memory.sizeof("decimal") == 8, "decimal should be 8 bytes");
});

test("Memory.sizeof bool is 1", () => {
    assert(Memory.sizeof("bool") == 1, "bool should be 1 byte");
});

test("sizeof(null) operator returns 0", () => {
    assert(sizeof(null) == 0, "null has no size");
});

test("sizeof result is an int (participates in arithmetic)", () => {
    let s = Memory.sizeof("int");
    assert(s + 0 == 8, "sizeof result participates in arithmetic");
});

summary();
