// Unit tests — control flow: if/else, while, for clásico, break, continue

// ── if / else if / else ───────────────────────────────────────────────────────

test("if simple true", () => {
    let x = 0;
    if (true) { x = 1; }
    assert(x == 1, "if ejecutado");
});

test("if simple false — no ejecuta body", () => {
    let x = 0;
    if (false) { x = 1; }
    assert(x == 0, "if no ejecutado");
});

test("if / else", () => {
    let r = "";
    if (5 > 10) { r = "mayor"; } else { r = "menor"; }
    assert(r == "menor", "else ejecutado");
});

test("if / else if / else", () => {
    fn string clasif(int n) {
        if (n > 0)      { return "positivo"; }
        else if (n < 0) { return "negativo"; }
        else            { return "cero"; }
    }
    assert(clasif(5)  == "positivo", "rama positivo");
    assert(clasif(-3) == "negativo", "rama negativo");
    assert(clasif(0)  == "cero",     "rama cero");
});

test("if anidado", () => {
    let x = 5;
    let r = "";
    if (x > 0) {
        if (x > 10) { r = "grande"; }
        else        { r = "pequeño"; }
    }
    assert(r == "pequeño", "if anidado");
});

test("if con expresiones complejas", () => {
    let a = 3;
    let b = 7;
    let r = 0;
    if (a > 0 && b > 0 && a + b == 10) { r = 1; }
    assert(r == 1, "condición compuesta");
});

// ── while ─────────────────────────────────────────────────────────────────────

test("while básico", () => {
    let i = 0;
    let sum = 0;
    while (i < 5) { sum += i; i++; }
    assert(sum == 10, "while 0+1+2+3+4=10");
});

test("while con break", () => {
    let i = 0;
    while (true) {
        if (i == 5) { break; }
        i++;
    }
    assert(i == 5, "break en while");
});

test("while con continue", () => {
    let i = 0;
    let sum = 0;
    while (i < 10) {
        i++;
        if (i % 2 == 0) { continue; }
        sum += i;
    }
    assert(sum == 25, "continue saltó pares: 1+3+5+7+9=25");
});

test("while anidado", () => {
    let count = 0;
    let i = 0;
    while (i < 3) {
        let j = 0;
        while (j < 3) { count++; j++; }
        i++;
    }
    assert(count == 9, "while anidado 3x3=9");
});

test("while no ejecuta si condición es false inicial", () => {
    let x = 0;
    while (false) { x = 1; }
    assert(x == 0, "while false no ejecuta");
});

// ── for clásico ───────────────────────────────────────────────────────────────

test("for con i = i + 1", () => {
    let sum = 0;
    for (let i = 0; i < 5; i = i + 1) { sum += i; }
    assert(sum == 10, "for i=i+1: 0+1+2+3+4=10");
});

test("for con i++", () => {
    let sum = 0;
    for (let i = 1; i <= 10; i++) { sum += i; }
    assert(sum == 55, "for i++: 1..10=55");
});

test("for con i--", () => {
    let vals = [];
    for (let i = 3; i >= 0; i--) { vals.push(i); }
    assert(vals[0] == 3 && vals[3] == 0, "for i-- descendente");
});

test("for con i += 2", () => {
    let sum = 0;
    for (let i = 0; i < 10; i += 2) { sum += i; }
    assert(sum == 20, "for i+=2: pares 0+2+4+6+8=20");
});

test("for con i *= 2", () => {
    let last = 1;
    for (let i = 1; i <= 16; i *= 2) { last = i; }
    assert(last == 16, "for i*=2: potencias de 2");
});

test("for con break", () => {
    let found = -1;
    for (let i = 0; i < 100; i++) {
        if (i * i > 50) { found = i; break; }
    }
    assert(found == 8, "for break: 8²=64>50");
});

test("for con continue", () => {
    let odds = 0;
    for (let i = 0; i < 10; i++) {
        if (i % 2 == 0) { continue; }
        odds += i;
    }
    assert(odds == 25, "for continue: impares 1+3+5+7+9=25");
});

test("for anidado", () => {
    let count = 0;
    for (let i = 0; i < 4; i++) {
        for (let j = 0; j < 4; j++) { count++; }
    }
    assert(count == 16, "for anidado 4x4=16");
});

test("for no ejecuta si condición inicial false", () => {
    let x = 0;
    for (let i = 10; i < 5; i++) { x++; }
    assert(x == 0, "for sin iteraciones");
});

summary();
