// Security: Tensor bounds and size limits

test("out-of-bounds get throws", () => {
    let t = Tensor.from([1, 2, 3]);
    let caught = false;
    try {
        let x = t.get(10);
    } catch (e) {
        caught = true;
    }
    assert(caught, "get out-of-bounds should throw");
});

test("negative index throws", () => {
    let t = Tensor.from([1, 2, 3]);
    let caught = false;
    try {
        let x = t.get(-1);
    } catch (e) {
        caught = true;
    }
    assert(caught, "negative index should throw");
});

test("reshape incompatible size throws", () => {
    let t = Tensor.from([1, 2, 3, 4]);
    let caught = false;
    try {
        let r = t.reshape([3, 3]);
    } catch (e) {
        caught = true;
    }
    assert(caught, "reshape with wrong total size should throw");
});

test("matmul dimension mismatch throws", () => {
    let a = Tensor.from([[1, 2], [3, 4]]);
    let b = Tensor.from([[1, 2, 3]]);
    let caught = false;
    try {
        let c = a.matmul(b);
    } catch (e) {
        caught = true;
    }
    assert(caught, "matmul mismatch should throw");
});

test("dot on 2D tensors throws", () => {
    let a = Tensor.from([[1, 2], [3, 4]]);
    let b = Tensor.from([[5, 6], [7, 8]]);
    let caught = false;
    try {
        let d = a.dot(b);
    } catch (e) {
        caught = true;
    }
    assert(caught, "dot on 2D should throw — use matmul");
});

test("wrong number of indices for get throws", () => {
    let t = Tensor.from([[1, 2], [3, 4]]);
    let caught = false;
    try {
        let x = t.get(0);
    } catch (e) {
        caught = true;
    }
    assert(caught, "1 index on 2D tensor should throw");
});

test("non-uniform 2D array in Tensor.from throws", () => {
    let caught = false;
    try {
        let t = Tensor.from([[1, 2, 3], [4, 5]]);
    } catch (e) {
        caught = true;
    }
    assert(caught, "non-uniform rows should throw");
});

test("Tensor.from with non-numeric elements throws", () => {
    let caught = false;
    try {
        let t = Tensor.from(["a", "b"]);
    } catch (e) {
        caught = true;
    }
    assert(caught, "non-numeric elements should throw");
});

summary();
