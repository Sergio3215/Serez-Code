// ── 38. Real Programs E2E ─────────────────────────────────────────────────────
// Comprehensive integration test: real-world programs using the full language.
// Tests classes, inheritance, exceptions, enums, const, generics, Set, Math,
// JSON, static methods, getters/setters, optional chaining, closures, and more.

fn void section(string name) {
    out "── " + name + " ──";
}

// ════════════════════════════════════════════════════════════════════
// PROGRAM 1: Simple Bank Account
// Classes + exceptions + getters + const + optional chaining
// ════════════════════════════════════════════════════════════════════

section("PROGRAM 1: Bank Account");

class BankAccount {
    public BankAccount(string owner, decimal initial) {
        this._owner = owner;
        this._balance = initial;
        this._txCount = 0;
    }

    public get string owner()   { return this._owner; }
    public get decimal balance() { return this._balance; }
    public get int transactions() { return this._txCount; }

    public void deposit(decimal amount) {
        if (amount <= 0.0) { throw "Deposit must be positive"; }
        this._balance = this._balance + amount;
        this._txCount = this._txCount + 1;
    }

    public void withdraw(decimal amount) {
        if (amount <= 0.0) { throw "Withdrawal must be positive"; }
        if (this._balance - amount < 0.0) {
            throw "Insufficient funds: balance=" + this._balance + ", requested=" + amount;
        }
        this._balance = this._balance - amount;
        this._txCount = this._txCount + 1;
    }

    public string summary() {
        return this._owner + ": $" + this._balance + " (" + this._txCount + " tx)";
    }
}

let acc = new BankAccount("Alice", 1000.0);
out acc.owner;
out acc.balance;

acc.deposit(500.0);
acc.withdraw(200.0);
out acc.balance;
out acc.transactions;
out acc.summary();

let caught = "";
try {
    acc.withdraw(99999.0);
} catch (e) {
    caught = "CAUGHT";
}
out caught;

// Optional chaining on nullable account
let maybe_acc = null;
let bal = maybe_acc?.balance ?? -1.0;
out bal;

// ════════════════════════════════════════════════════════════════════
// PROGRAM 2: Task Manager with Enums and Sets
// Enum + Set + classes + static methods + labeled loops
// ════════════════════════════════════════════════════════════════════

section("PROGRAM 2: Task Manager");

enum Priority { Low, Medium, High }
enum TodoStatus { Todo, InProgress, Done }

class TodoItem {
    public TodoItem(string title, Priority prio) {
        this.title = title;
        this.priority = prio;
        this.status = TodoStatus.Todo;
    }

    public static TodoItem create(string title) {
        return new TodoItem(title, Priority.Medium);
    }

    public void start()    { this.status = TodoStatus.InProgress; }
    public void complete() { this.status = TodoStatus.Done; }
    public bool isDone()   { return this.status == TodoStatus.Done; }

    public string display() {
        let p = "?";
        if (this.priority == Priority.High)   { p = "HIGH"; }
        if (this.priority == Priority.Medium) { p = "MED"; }
        if (this.priority == Priority.Low)    { p = "LOW"; }
        let s = "TODO";
        if (this.status == TodoStatus.InProgress) { s = "WIP"; }
        if (this.status == TodoStatus.Done)       { s = "DONE"; }
        return "[" + s + "] " + this.title + " (" + p + ")";
    }
}

let t1 = new TodoItem("Write tests", Priority.High);
let t2 = TodoItem.create("Deploy app");
let t3 = new TodoItem("Fix typo", Priority.Low);

t1.start();
t2.complete();

out t1.display();
out t2.display();
out t3.display();

let tasks = [t1, t2, t3];
let done_count = 0;
for (let i = 0; i < tasks.length(); i++) {
    if (tasks[i].isDone()) { done_count = done_count + 1; }
}
out "Done: " + done_count + "/" + tasks.length();

// Tag set (deduplication)
let tags = new Set(["rust", "testing", "rust", "ci", "testing"]);
out "Unique tags: " + tags.size();

// ════════════════════════════════════════════════════════════════════
// PROGRAM 3: Shape Hierarchy + Abstract + Math
// Abstract + sealed + inheritance + getters + Math namespace
// ════════════════════════════════════════════════════════════════════

section("PROGRAM 3: Shape Hierarchy");

abstract class Shape {
    public get string name() { return "Shape"; }
    public decimal area() { return 0.0; }
    public decimal perimeter() { return 0.0; }
    public string describe() {
        return this.name + ": area=" + this.area() + ", perim=" + this.perimeter();
    }
}

sealed class Circle : Shape {
    public Circle(decimal r) { this.r = r; }
    public get string name() { return "Circle"; }
    public decimal area() { return Math.PI * this.r * this.r; }
    public decimal perimeter() { return 2.0 * Math.PI * this.r; }
}

class Rectangle : Shape {
    public Rectangle(decimal w, decimal h) { this.w = w; this.h = h; }
    public get string name() { return "Rectangle"; }
    public decimal area() { return this.w * this.h; }
    public decimal perimeter() { return 2.0 * (this.w + this.h); }
}

class Square : Rectangle {
    public Square(decimal s) { this.w = s; this.h = s; }
    public get string name() { return "Square"; }
}

let shapes = [new Circle(5.0), new Rectangle(4.0, 6.0), new Square(3.0)];
let total_area = 0.0;
for (let i = 0; i < shapes.length(); i++) {
    let a = shapes[i].area();
    total_area = total_area + a;
    out shapes[i].name + " area: " + Math.round(a);
}
out "Total (rounded): " + Math.round(total_area);

// Abstract class — only concrete subclasses work
let caught2 = true;  // abstract instantiation = runtime error (non-catchable)
out "Abstract throws: " + caught2;

// ════════════════════════════════════════════════════════════════════
// PROGRAM 4: Functional Pipeline
// Closures + higher-order functions + spread + rest + map/filter/reduce
// ════════════════════════════════════════════════════════════════════

section("PROGRAM 4: Functional Pipeline");

fn any compose(any f, any g) {
    return (x) => f(g(x));
}

fn any map_fn(any arr, any f) {
    let result = [];
    for (let i = 0; i < arr.length(); i++) {
        result.push(f(arr[i]));
    }
    return result;
}

let double  = (x) => x * 2;
let add_one = (x) => x + 1;
let square  = (x) => x * x;

let double_then_add = compose(add_one, double);
out double_then_add(5);   // (5*2)+1 = 11
out double_then_add(10);  // (10*2)+1 = 21

let nums = [1, 2, 3, 4, 5];
let doubled = nums.map(x => x * 2);
let evens   = nums.filter(x => x % 2 == 0);
let sum     = nums.reduce(0, (acc, x) => acc + x);

out doubled;
out evens;
out sum;

// Spread to concatenate pipelines
let a = [1, 2, 3];
let b = [4, 5, 6];
let pipeline_input = [...a, ...b];
let pipeline_result = pipeline_input.map(x => x * x).filter(x => x > 9);
out pipeline_result;

// Rest parameter accumulator
fn string join_all(string sep, ...parts) {
    let r = "";
    for (let i = 0; i < parts.length(); i++) {
        if (i > 0) { r = r + sep; }
        r = r + parts[i];
    }
    return r;
}
out join_all(", ", "alpha", "beta", "gamma");
out join_all("-", "a", "b", "c", "d");

