section("PROGRAM 5: JSON Config");

// JSON stringify primitives
out JSON.stringify(42);
out JSON.stringify("hello world");
out JSON.stringify(true);
out JSON.stringify(null);

// Parse simple values
out JSON.parse("42");
out JSON.parse("true");
out JSON.parse("false");
out JSON.parse("null");

// Array stringify
let scores = [98, 87, 76];
let scores_json = JSON.stringify(scores);
out scores_json;

// String roundtrip
let s_json = JSON.stringify("test");
let s_back = JSON.parse(s_json);
out s_back == "test";

