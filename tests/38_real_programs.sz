// PROGRAM 8: String Processing
// String methods + trimLeft/trimRight + padStart + slice + split + join
// ════════════════════════════════════════════════════════════════════

section("PROGRAM 8: String Processing");

fn string format_number(int n, int width) {
    return n.toString().padStart(width, "0");
}

fn string csv_line(string name, int score, int rank) {
    return name + "," + score + "," + format_number(rank, 3);
}

out format_number(7, 4);
out format_number(42, 4);
out format_number(999, 4);

out csv_line("Alice", 98, 1);
out csv_line("Bob", 87, 10);
out csv_line("Charlie", 76, 100);

// String processing pipeline
let raw = "  hello, world  ";
let cleaned = raw.trimLeft().trimRight();
out cleaned;

let words = cleaned.split(", ");
out words.length();
out words[0].toUpperCase();
out words[1].toUpperCase();

// Pad and center-ish
let title = "RESULTS";
let padded = title.padStart(12, " ").padEnd(17, " ");
out padded.length();

// Slice
let s = "Hello, World!";
out s.slice(0, 5);
out s.slice(7, 12);

out "";
out "══════════════════════════════════════";
out "  38. REAL PROGRAMS E2E PASSED ✓";
out "══════════════════════════════════════";
