// PROGRAM 6: Recursive Algorithms + Math
// Recursion + Math + bitwise + power operator
// ════════════════════════════════════════════════════════════════════

section("PROGRAM 6: Algorithms");

fn int factorial(int n) {
    if (n <= 1) { return 1; }
    return n * factorial(n - 1);
}
out factorial(10);

fn int fib(int n) {
    if (n <= 1) { return n; }
    return fib(n - 1) + fib(n - 2);
}
out fib(10);

// Power of 2 check using bitwise
fn bool is_power_of_two(int n) {
    if (n <= 0) { return false; }
    return (n & (n - 1)) == 0;
}
out is_power_of_two(1);
out is_power_of_two(8);
out is_power_of_two(16);
out is_power_of_two(7);
out is_power_of_two(0);

// Count set bits (Brian Kernighan)
fn int count_bits(int n) {
    let count = 0;
    let v = n;
    do {
        if (v == 0) { break; }
        v = v & (v - 1);
        count = count + 1;
    } while (true);
    return count;
}
out count_bits(255);   // 8
out count_bits(0xFF);  // 8
out count_bits(7);     // 3

// Newton's square root approximation
fn decimal my_sqrt(decimal n) {
    let guess = n / 2.0;
    let i = 0;
    while (i < 20) {
        guess = (guess + n / guess) / 2.0;
        i = i + 1;
    }
    return Math.round(guess * 1000.0) / 1000.0;
}
out my_sqrt(2.0);
out my_sqrt(9.0);
out my_sqrt(16.0);

// ════════════════════════════════════════════════════════════════════
// PROGRAM 7: Error Handling Patterns
// Exceptions + try/catch/finally + throw objects + is type check
// ════════════════════════════════════════════════════════════════════

section("PROGRAM 7: Error Handling");

class AppError {
    public AppError(string code, string msg) {
        this.code = code;
        this.msg = msg;
    }
    public string toString() { return "[" + this.code + "] " + this.msg; }
}

class NetworkError : AppError {
    public NetworkError(int status) {
        this.code = "NET";
        this.msg = "HTTP " + status;
        this.status = status;
    }
    public bool isClientError() { return this.status >= 400 && this.status < 500; }
}

fn string fetch(int url_code) {
    if (url_code == 404) { throw new NetworkError(404); }
    if (url_code == 500) { throw new NetworkError(500); }
    if (url_code == 0)   { throw new AppError("INVALID", "Bad URL"); }
    return "OK: " + url_code;
}

let results = [200, 404, 500, 0, 201];
for (let i = 0; i < results.length(); i++) {
    let code = results[i];
    try {
        let r = fetch(code);
        out "Success: " + r;
    } catch (e) {
        if (e is NetworkError) {
            out "Network: " + e.msg + " (client=" + e.isClientError() + ")";
        } else if (e is AppError) {
            out "App: " + e.toString();
        } else {
            out "Unknown: " + e;
        }
    }
}

// Finally in resource management pattern
let resource_closed = false;
try {
    let data = fetch(200);
    out data;
} catch (e) {
    out "Failed";
} finally {
    resource_closed = true;
}
out "Resource closed: " + resource_closed;

