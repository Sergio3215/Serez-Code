// 04 - Control de flujo

// If / else
let x = 10;
if (x > 5) {
    out "mayor que 5";
} else {
    out "menor o igual a 5";
}

// If / else if / else
let nota = 75;
if (nota >= 90) {
    out "A";
} else if (nota >= 80) {
    out "B";
} else if (nota >= 70) {
    out "C";
} else {
    out "D";
}

// Condicion compuesta
let a = true;
let b = false;
if (a && !b) {
    out "a es true y b es false";
}
if (a || b) {
    out "al menos uno es true";
}

// While basico
let i = 0;
while (i < 5) {
    out i;
    i = i + 1;
}

// While con break
let j = 0;
while (true) {
    if (j == 3) {
        break;
    }
    out j;
    j = j + 1;
}

// While con continue
let k = 0;
while (k < 8) {
    k = k + 1;
    if (k % 2 == 0) {
        continue;
    }
    out k;
}

// For clasico
for (let n = 0; n < 5; n = n + 1) {
    out n;
}

// For con break
for (let m = 0; m < 100; m = m + 1) {
    if (m > 3) {
        break;
    }
    out m;
}

// For con continue - solo pares
for (let p = 0; p < 10; p = p + 1) {
    if (p % 2 != 0) {
        continue;
    }
    out p;
}

// If como expresion (devuelve valor)
let max = if (5 > 3) { 5 } else { 3 };
out max;

// Anidado
let resultado = 0;
for (let r = 1; r <= 3; r = r + 1) {
    let inner = 0;
    for (let c = 1; c <= 3; c = c + 1) {
        inner = inner + r * c;
    }
    resultado = resultado + inner;
}
out resultado;
