// Unit-security tests: WebSocket crypto correctness and determinism
//
// NOTE: Crypto.sha1 / Crypto.sha1base64 / Socket.sendWsFrame reject invalid
// argument types (int, null, array, missing) with a NON-CATCHABLE runtime error
// by design (see README "Runtime Safety"). Those rejection paths terminate the
// program, so they cannot be wrapped in try/catch and asserted in a unit test —
// they are exercised by the dedicated sec_/err_ error-path tests. This file
// verifies the security-critical property that the VALID paths are correct and
// deterministic (a wrong SHA-1 would break the WebSocket handshake).

test("sha1 produces correct RFC 3174 vectors", () => {
    assert(Crypto.sha1("")    == "da39a3ee5e6b4b0d3255bfef95601890afd80709", "empty string vector");
    assert(Crypto.sha1("abc") == "a9993e364706816aba3e25717850c26c9cd0d89d", "abc vector");
});

test("sha1 is deterministic (idempotent)", () => {
    assert(Crypto.sha1("serez") == Crypto.sha1("serez"), "same input → same hash");
    let h1 = Crypto.sha1("");
    let h2 = Crypto.sha1("");
    assert(h1 == h2, "empty string idempotent");
});

test("sha1 distinguishes different inputs", () => {
    assert(Crypto.sha1("a") != Crypto.sha1("b"), "distinct inputs → distinct hashes");
});

test("sha1base64 produces stable non-empty output", () => {
    let b1 = Crypto.sha1base64("serez");
    let b2 = Crypto.sha1base64("serez");
    assert(b1 == b2,         "deterministic");
    assert(b1.length() > 0,  "non-empty");
});

summary();
