// Unit tests — funciones: tipado, recursión, params, default, HOF

test("función sin tipo de retorno", () => {
    fn int suma(int a, int b) { return a + b; }
    assert(suma(3, 4) == 7,  "suma 3+4");
    assert(suma(0, 0) == 0,  "suma 0+0");
    assert(suma(-1, 1) == 0, "suma -1+1");
});

test("función string", () => {
    fn string saludar(string nombre) {
        return "Hola, " + nombre + "!";
    }
    assert(saludar("Sergio") == "Hola, Sergio!", "saludar");
    assert(saludar("mundo")  == "Hola, mundo!",  "saludar 2");
});

test("función bool", () => {
    fn bool es_par(int n) { return n % 2 == 0; }
    assert(es_par(4)  == true,  "es_par 4");
    assert(es_par(7)  == false, "es_par 7");
    assert(es_par(0)  == true,  "es_par 0");
});

test("función múltiples parámetros tipados", () => {
    fn decimal promedio(int a, int b, int c) {
        return (a + b + c) / 3;
    }
    assert(promedio(3, 6, 9) == 6, "promedio 3 6 9");
});

test("recursión — factorial", () => {
    fn int factorial(int n) {
        if (n <= 1) { return 1; }
        return n * factorial(n - 1);
    }
    assert(factorial(0)  == 1,       "factorial 0");
    assert(factorial(1)  == 1,       "factorial 1");
    assert(factorial(5)  == 120,     "factorial 5");
    assert(factorial(10) == 3628800, "factorial 10");
});

test("recursión — fibonacci", () => {
    fn int fib(int n) {
        if (n <= 1) { return n; }
        return fib(n - 1) + fib(n - 2);
    }
    assert(fib(0)  == 0,  "fib 0");
    assert(fib(1)  == 1,  "fib 1");
    assert(fib(7)  == 13, "fib 7");
    assert(fib(10) == 55, "fib 10");
});

test("early return", () => {
    fn string clasificar(int n) {
        if (n > 0)  { return "positivo"; }
        if (n < 0)  { return "negativo"; }
        return "cero";
    }
    assert(clasificar(5)  == "positivo", "positivo");
    assert(clasificar(-3) == "negativo", "negativo");
    assert(clasificar(0)  == "cero",     "cero");
});

test("función retorna array", () => {
    fn [int] rango(int n) {
        let a [int] = [];
        let i = 0;
        while (i < n) {
            a.push(i);
            i++;
        }
        return a;
    }
    let r = rango(5);
    assert(r.length() == 5, "rango length");
    assert(r[0] == 0 && r[4] == 4, "rango valores");
});

test("función retorna null nullable", () => {
    fn int? buscar(int target, [int] arr) {
        let i = 0;
        while (i < arr.length()) {
            if (arr[i] == target) { return i; }
            i++;
        }
        return null;
    }
    assert(buscar(3, [1,2,3,4]) == 2,   "buscar encontrado");
    assert(buscar(9, [1,2,3,4]) == null, "buscar no encontrado");
});

test("funciones como argumentos", () => {
    fn int aplicar(int x, any f) { return f(x); }
    assert(aplicar(5, x => x * x)  == 25, "aplicar cuadrado");
    assert(aplicar(10, x => x + 1) == 11, "aplicar +1");
});

test("función devuelve función", () => {
    fn any make_sumador(int n) { return x => x + n; }
    let add3  = make_sumador(3);
    let add10 = make_sumador(10);
    assert(add3(7)  == 10, "sumador 3");
    assert(add10(5) == 15, "sumador 10");
    assert(add3(add10(1)) == 14, "sumadores anidados");
});

test("params con valores por defecto", () => {
    fn string etiqueta(string texto, string prefijo = ">> ") {
        return prefijo + texto;
    }
    assert(etiqueta("hola")         == ">> hola",   "default prefix");
    assert(etiqueta("hola", "-- ")  == "-- hola",   "custom prefix");
});

test("función void no retorna valor usable", () => {
    let contador = 0;
    fn void incrementar() { contador = contador + 1; }
    incrementar();
    incrementar();
    assert(contador == 2, "void modifica outer");
});

summary();
