// E2E: Neural network training end-to-end
// Trains a 2-layer NN (Dense + sigmoid) on a linearly separable task.
// Fixed seed for determinism. All outputs are boolean or integer.
//
// Task: x1 > 0 AND x2 > 0 → class 1; otherwise class 0
// Architecture: x[1,2] → Dense(2,4,"relu") → Dense(4,1,"sigmoid") → MSE
// Verifies: loss decreases, final predictions correct, gradients flow.

Random.seed(101)

// ── Weights ───────────────────────────────────────────────────────────────────
let W1 = Random.normalTensor([2, 4], 0.0, 0.5)
let b1 = Tensor.zeros([4])
let W2 = Random.normalTensor([4, 1], 0.0, 0.5)
let b2 = Tensor.zeros([1])
let lr = 0.1

// ── Dataset: 4 canonical quadrant samples ────────────────────────────────────
// (++) → 1.0,  (+-) → 0.0,  (-+) → 0.0,  (--) → 0.0
let samples = [
    Tensor.from([[1.0,  1.0]]),
    Tensor.from([[1.0, -1.0]]),
    Tensor.from([[-1.0, 1.0]]),
    Tensor.from([[-1.0,-1.0]])
]
let targets = [
    Tensor.from([[1.0]]),
    Tensor.from([[0.0]]),
    Tensor.from([[0.0]]),
    Tensor.from([[0.0]])
]

// ── Forward pass ──────────────────────────────────────────────────────────────
fn fwd(x) {
    let h1  = x.matmul(W1).broadcastAdd(b1)
    let a1  = h1.relu()
    let out_ = a1.matmul(W2).broadcastAdd(b2)
    return out_.sigmoid()
}

// ── Compute total MSE loss (no tape) ─────────────────────────────────────────
fn total_loss() {
    let L = 0.0
    let i = 0
    while (i < 4) {
        let pred = fwd(samples[i])
        let diff = pred.sub(targets[i])
        L = L + diff.mul(diff).get(0, 0)
        i = i + 1
    }
    return L
}

// ── Record initial loss ───────────────────────────────────────────────────────
let L0 = total_loss()

// ── Training: 80 epochs ───────────────────────────────────────────────────────
let epoch = 0
while (epoch < 80) {
    let i = 0
    while (i < 4) {
        Autodiff.tape()
        let pred = fwd(samples[i])
        let diff = pred.sub(targets[i])
        let lt   = diff.mul(diff)
        Autodiff.backward(lt)
        W1 = W1.sub(Autodiff.gradient(W1).scale(lr))
        b1 = b1.sub(Autodiff.gradient(b1).scale(lr))
        W2 = W2.sub(Autodiff.gradient(W2).scale(lr))
        b2 = b2.sub(Autodiff.gradient(b2).scale(lr))
        i = i + 1
    }
    epoch = epoch + 1
}

// ── Record final loss ─────────────────────────────────────────────────────────
let Lf = total_loss()

// ── Outputs (all booleans or integers) ───────────────────────────────────────

// 1. Loss decreased
out (Lf < L0)

// 2. Loss reduced significantly (> 20%)
out ((L0 - Lf) / L0 > 0.2)

// 3. Positive sample (++): prediction > 0.5
let p_pp = fwd(samples[0]).get(0, 0)
out (p_pp > 0.5)

// 4. Negative samples: predictions < 0.5 (at least 2 of 3)
let p_pn = fwd(samples[1]).get(0, 0)
let p_np = fwd(samples[2]).get(0, 0)
let p_nn = fwd(samples[3]).get(0, 0)
let neg_correct = 0
if (p_pn < 0.5) { neg_correct = neg_correct + 1 }
if (p_np < 0.5) { neg_correct = neg_correct + 1 }
if (p_nn < 0.5) { neg_correct = neg_correct + 1 }
out (neg_correct >= 2)

// 5. Positive pred > all negative preds
out (p_pp > p_pn && p_pp > p_np && p_pp > p_nn)

// 6. All predictions in (0,1)
let in_range = true
if (p_pp <= 0.0 || p_pp >= 1.0) { in_range = false }
if (p_pn <= 0.0 || p_pn >= 1.0) { in_range = false }
if (p_np <= 0.0 || p_np >= 1.0) { in_range = false }
if (p_nn <= 0.0 || p_nn >= 1.0) { in_range = false }
out in_range

// 7. W1 changed from initial (gradient flowed)
// Just verify W1 has non-trivial values (it's been updated from random init)
let w1_norm = W1.norm()
out (w1_norm > 0.0)

// 8. Total samples and epochs
out 4
out 80
