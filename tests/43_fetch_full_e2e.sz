// E2E: fetch full-mode (status + headers as a structured object).
// Uses PokeAPI — a stable, CDN-backed endpoint that consistently returns
// 200 — so we can assert the real response instead of just tolerating it.
// Still network-tolerant: a genuine network outage fails gracefully.

native fn any fetch(string url, any options);

let status = "unknown";
let opts <string, any> = ({"full", true});

try {
    let r = fetch("https://pokeapi.co/api/v2/pokemon/ditto", opts);
    // full mode returns a dict { status, ok, statusText, headers, body }.
    // Assert the actual response: a 200 with the expected payload proves the
    // status line, headers and body are all parsed correctly.
    if (r["status"] == 200
        && r["ok"] == true
        && r["statusText"] != null
        && r["headers"] != null
        && r["body"].includes("ditto")) {
        status = "ok";
    }
} catch (e) {
    // No HTTP reply at all (network down) — acceptable
    status = "network_error";
}

out status == "ok" || status == "network_error";
