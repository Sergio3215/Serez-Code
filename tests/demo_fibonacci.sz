// DEMO - Fibonacci: recursivo, iterativo y con memoization

fn int fib_rec(int n) {
    if (n <= 1) { return n; }
    return fib_rec(n - 1) + fib_rec(n - 2);
}

fn int fib_iter(int n) {
    if (n <= 1) { return n; }
    let a = 0;
    let b = 1;
    for (let i = 2; i <= n; i = i + 1) {
        let c = a + b;
        a = b;
        b = c;
    }
    return b;
}

out "=== Fibonacci Recursivo ===";
for (let i = 0; i <= 10; i = i + 1) {
    out "fib({i}) = {fib_rec(i)}";
}

out "";
out "=== Fibonacci Iterativo (mas rapido) ===";
for (let i = 0; i <= 20; i = i + 1) {
    out "fib({i}) = {fib_iter(i)}";
}
