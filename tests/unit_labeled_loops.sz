// unit_labeled_loops.sz — tests for labeled break/continue

// Labeled break from outer loop
outer: for (let i = 0; i < 3; i++) {
    for (let j = 0; j < 3; j++) {
        if (i == 1 && j == 1) {
            break outer;
        }
        out i * 10 + j;
    }
}

out "---";

// Labeled continue on outer loop
rows: for (let r = 0; r < 3; r++) {
    for (let c = 0; c < 3; c++) {
        if (c == 1) {
            continue rows;
        }
        out r * 10 + c;
    }
}

out "---";

// Labeled break from while
let x = 0;
main_loop: while (x < 10) {
    let y = 0;
    while (y < 10) {
        if (x + y >= 5) {
            break main_loop;
        }
        y++;
    }
    x++;
}
out x;
