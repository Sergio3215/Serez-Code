// E2E: WebSocket core — SHA-1, sha1base64, WS frame round-trip

// ── Crypto.sha1 ───────────────────────────────────────────────────────────────
out Crypto.sha1("");
out Crypto.sha1("abc");
out Crypto.sha1("The quick brown fox jumps over the lazy dog");

// ── Crypto.sha1base64 — RFC 6455 handshake vector ────────────────────────────
let ws_key   = "dGhlIHNhbXBsZSBub25jZQ==";
let ws_magic = "258EAFA5-E914-47DA-95CA-C5AB0DC85B11";
out Crypto.sha1base64(ws_key + ws_magic);

// ── WebSocket frame round-trip ────────────────────────────────────────────────
let srv  = Socket.listen(19940);
let cli  = Socket.connect("127.0.0.1", 19940);
let conn = Socket.accept(srv);

Socket.sendWsFrame(cli, "ping");
out Socket.recvWsFrame(conn);

Socket.sendWsFrame(conn, "pong");
out Socket.recvWsFrame(cli);

Socket.sendWsFrame(cli, "serez websocket");
out Socket.recvWsFrame(conn);

Socket.close(cli);
Socket.close(conn);
Socket.close(srv);
out "done";
