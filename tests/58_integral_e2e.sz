// ─────────────────────────────────────────────────────────────────────────────
// TEST INTEGRAL — Serez-Code v2.1.0
// Exercises every namespace and language feature in a single cohesive run.
// Covers: core language, Crypto, Binary, Memory, GPU, Tensor, native builtins,
//         packages, classes, closures, match, generators, async-style patterns.
// ─────────────────────────────────────────────────────────────────────────────

out "=== CORE ===";

// Classes, inheritance, closures, match
class Shape {
    public Shape(string kind, decimal area) {
        this.kind = kind;
        this.area = area;
    }
    public string describe() {
        return "{this.kind}:{this.area}";
    }
}

class Circle : Shape {
    public Circle(decimal r) {
        super("circle", Math.round(Math.PI * r * r * 100.0) / 100.0);
        this.r = r;
    }
}

let c = new Circle(3.0);
out c.describe();

// Closures
fn any makeCounter(int start) {
    let n = start;
    return () => {
        n = n + 1;
        return n;
    };
}
let counter = makeCounter(0);
out counter();
out counter();
out counter();

// Match
fn string classify(int x) {
    return match x {
        0 => "zero"
        _ => x > 0 ? "positive" : "negative"
    };
}
out classify(0);
out classify(5);
out classify(-3);

// Generator
fn* int fib(int n) {
    let a = 0;
    let b = 1;
    let i = 0;
    while (i < n) {
        yield a;
        let tmp = a + b;
        a = b;
        b = tmp;
        i = i + 1;
    }
}
let fibs = fib(7);
out fibs.join(",");

// Destructuring
let [first, second, ...rest] = [10, 20, 30, 40, 50];
out first;
out second;
out rest.length;

out "=== CRYPTO ===";

// SHA-256 of known string
let h = Crypto.sha256("serez");
out h.length == 64;
out h.substring(0, 8);

// HMAC
let mac = Crypto.hmacSha256("key", "msg");
out mac.length == 64;

// Base64
let b64 = Crypto.base64encode("hello");
out b64;

out "=== BINARY ===";

// Hex round-trip
let hexed = Binary.toHex([0xDE, 0xAD, 0xBE, 0xEF]);
out hexed;
let bytes = Binary.fromHex(hexed);
out bytes[0];
out bytes[3];

// Pack/unpack int32
let packed = Binary.packInt32Le(305419896);
out Binary.unpackInt32Le(packed);

// UTF-8 round-trip
let utf8 = Binary.fromUtf8("AB");
out utf8[0];
out utf8[1];

out "=== MEMORY ===";

// Alloc, write, read, free — all within unsafe blocks
let mem = unsafe { Memory.alloc(32) };
out Memory.size(mem) == 32;

unsafe { Memory.write(mem, 0,  "int64", 111) };
unsafe { Memory.write(mem, 8,  "int64", 222) };
unsafe { Memory.write(mem, 16, "int64", 333) };

out unsafe { Memory.read(mem, 0,  "int64") };
out unsafe { Memory.read(mem, 8,  "int64") };
out unsafe { Memory.read(mem, 16, "int64") };

// Copy
let mem2 = unsafe { Memory.alloc(32) };
unsafe { Memory.copy(mem, mem2, 24) };
out unsafe { Memory.read(mem2, 0, "int64") };

unsafe { Memory.free(mem) };
unsafe { Memory.free(mem2) };
out Memory.sizeof("int32");

out "=== GPU ===";

// Matrix multiply via GPU buffers: A(2x2) * B(2x2)
let a = GPU.createBufferFromArray([1.0, 2.0, 3.0, 4.0]);
let b = GPU.createBufferFromArray([2.0, 0.0, 0.0, 2.0]);
let result = GPU.matmul(a, 2, 2, b, 2, 2);
let r = GPU.readBuffer(result);
out r[0];
out r[1];
out r[2];
out r[3];
GPU.freeBuffer(a);
GPU.freeBuffer(b);
GPU.freeBuffer(result);

// map + reduce
let buf = GPU.createBuffer(4);
GPU.fill(buf, 3.0);
let mapped = GPU.map(buf, (x) => x * x);
let total = GPU.reduce(mapped, (acc, x) => acc + x, 0.0);
out total;
GPU.freeBuffer(buf);
GPU.freeBuffer(mapped);

out "=== TENSOR ===";

// Basic ops
let t = Tensor.from([1.0, -2.0, 3.0, -4.0]);
let relu_t = t.relu();
out relu_t.get(0);
out relu_t.get(1);
out relu_t.get(2);
out relu_t.get(3);

// Activations
let t2 = Tensor.zeros([1]);
let sig = t2.sigmoid();
out (sig.get(0) > 0.49 && sig.get(0) < 0.51);

// Softmax sums to 1
let t3 = Tensor.from([2.0, 1.0, 0.5]);
let sm = t3.softmax();
let sm_sum = sm.get(0) + sm.get(1) + sm.get(2);
out (sm_sum > 0.999 && sm_sum < 1.001);

// Norm of [3,4] = 5
let t4 = Tensor.from([3.0, 4.0]);
out (t4.norm() > 4.99 && t4.norm() < 5.01);

// pow + sqrt inverse
let t5 = Tensor.from([4.0, 9.0]);
let sq = t5.sqrt();
out (sq.get(0) > 1.99 && sq.get(0) < 2.01);

// clamp
let t6 = Tensor.from([-10.0, 5.0, 20.0]);
let cl = t6.clamp(0, 10);
out cl.get(0);
out cl.get(1);
out cl.get(2);

// 2D matmul
let m1 = Tensor.from([[1.0, 2.0], [3.0, 4.0]]);
let m2 = Tensor.from([[1.0, 0.0], [0.0, 1.0]]);
let mm = m1.matmul(m2);
out mm.get(0, 0);
out mm.get(1, 1);

// broadcastAdd
let mat = Tensor.from([[1.0, 2.0], [3.0, 4.0]]);
let bias = Tensor.from([10.0, 20.0]);
let ba = mat.broadcastAdd(bias);
out ba.get(0, 0);
out ba.get(1, 1);

out "=== BUILTINS ===";

// time returns positive int
out (time() > 0);

// env for missing var returns empty
out (env("__SEREZ_INTEGRAL_TEST_MISSING__") == "");

out "=== PACKAGES ===";

import "math-helpers";
out clamp(5, 0, 10);
out clamp(-5, 0, 10);
out (factorial(5) == 120);

out "=== DONE ===";
