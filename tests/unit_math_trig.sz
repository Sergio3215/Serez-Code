// Unit tests: Math trigonometric and logarithmic functions not in unit_math_builtins

test("Math.tan — basic values", () => {
    // tan(0) = 0
    assert(Math.tan(0.0) > -0.001 && Math.tan(0.0) < 0.001, "tan(0) ≈ 0");
    // tan(π/4) = 1
    let t45 = Math.tan(Math.PI / 4.0);
    assert(t45 > 0.999 && t45 < 1.001, "tan(π/4) ≈ 1");
});

test("Math.atan — basic values", () => {
    // atan(0) = 0
    assert(Math.atan(0.0) > -0.001 && Math.atan(0.0) < 0.001, "atan(0) ≈ 0");
    // atan(1) = π/4
    let a = Math.atan(1.0);
    assert(a > 0.785 && a < 0.786, "atan(1) ≈ π/4");
});

test("Math.atan2 — quadrant angles", () => {
    // atan2(1,1) = π/4
    let a1 = Math.atan2(1.0, 1.0);
    assert(a1 > 0.785 && a1 < 0.786, "atan2(1,1) ≈ π/4");
    // atan2(0,1) = 0
    let a2 = Math.atan2(0.0, 1.0);
    assert(a2 > -0.001 && a2 < 0.001, "atan2(0,1) ≈ 0");
    // atan2(1,0) = π/2
    let a3 = Math.atan2(1.0, 0.0);
    assert(a3 > 1.570 && a3 < 1.572, "atan2(1,0) ≈ π/2");
});

test("Math.log2 — powers of 2", () => {
    assert(Math.log2(1.0) > -0.001 && Math.log2(1.0) < 0.001, "log2(1) = 0");
    let l2 = Math.log2(2.0);
    assert(l2 > 0.999 && l2 < 1.001, "log2(2) = 1");
    let l8 = Math.log2(8.0);
    assert(l8 > 2.999 && l8 < 3.001, "log2(8) = 3");
    let l1024 = Math.log2(1024.0);
    assert(l1024 > 9.999 && l1024 < 10.001, "log2(1024) = 10");
});

test("Math.log10 — powers of 10", () => {
    let l1 = Math.log10(1.0);
    assert(l1 > -0.001 && l1 < 0.001, "log10(1) = 0");
    let l10 = Math.log10(10.0);
    assert(l10 > 0.999 && l10 < 1.001, "log10(10) = 1");
    let l100 = Math.log10(100.0);
    assert(l100 > 1.999 && l100 < 2.001, "log10(100) = 2");
    let l1000 = Math.log10(1000.0);
    assert(l1000 > 2.999 && l1000 < 3.001, "log10(1000) = 3");
});

test("Math.trunc — truncate toward zero", () => {
    assert(Math.trunc(3.9)  == 3,  "trunc(3.9) = 3");
    assert(Math.trunc(3.1)  == 3,  "trunc(3.1) = 3");
    assert(Math.trunc(-3.9) == -3, "trunc(-3.9) = -3");
    assert(Math.trunc(-3.1) == -3, "trunc(-3.1) = -3");
    assert(Math.trunc(0.9)  == 0,  "trunc(0.9) = 0");
});

test("Math.sign — sign of number", () => {
    assert(Math.sign(5)    == 1,  "sign(5) = 1");
    assert(Math.sign(-3)   == -1, "sign(-3) = -1");
    assert(Math.sign(0)    == 0,  "sign(0) = 0");
    assert(Math.sign(0.1)  == 1,  "sign(0.1) = 1");
    assert(Math.sign(-0.1) == -1, "sign(-0.1) = -1");
});

test("asin/acos round-trip with sin/cos", () => {
    // asin(sin(x)) ≈ x for x in [-π/2, π/2]
    let x = 0.5;
    let roundtrip = Math.asin(Math.sin(x));
    assert(roundtrip > x - 0.001 && roundtrip < x + 0.001, "asin(sin(0.5)) ≈ 0.5");
    // acos(cos(x)) ≈ x for x in [0, π]
    let y = 1.0;
    let rt2 = Math.acos(Math.cos(y));
    assert(rt2 > y - 0.001 && rt2 < y + 0.001, "acos(cos(1.0)) ≈ 1.0");
});

summary();
