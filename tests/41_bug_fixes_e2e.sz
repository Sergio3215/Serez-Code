// ── 41. Bug Fixes E2E ─────────────────────────────────────────────────────────
// Integration test for the 4 bugs fixed in commit dcd5785:
// Bug 1: pop() on empty array → ❌
// Bug 2: shift() on empty array → ❌
// Bug 3: 2 ** 63 overflow → ❌ (f64 precision fix via checked_pow)
// Bug 4: typed dict missing key → ❌

out "── bug 1 & 2: bounded queue simulation ──";

// A Queue class that prevents pop/shift on empty using a length guard
class Queue {
    public Queue() { this._data = []; }
    public void enqueue(any v) { this._data.push(v); }
    public any dequeue() {
        if (this._data.length() == 0) { return null; }
        return this._data.shift();
    }
    public any peek() {
        if (this._data.length() == 0) { return null; }
        return this._data[0];
    }
    public int size() { return this._data.length(); }
    public bool isEmpty() { return this._data.length() == 0; }
}

let q = new Queue();
q.enqueue(10);
q.enqueue(20);
q.enqueue(30);
out q.size();          // 3
out q.peek();          // 10
out q.dequeue();       // 10
out q.dequeue();       // 20
out q.size();          // 1
out q.isEmpty();       // false
out q.dequeue();       // 30
out q.isEmpty();       // true
out q.dequeue();       // null (guarded — does not call shift on empty)

out "── bug 1 & 2: safe stack with guard ──";

class SafeStack {
    public SafeStack() { this._items = []; }
    public void push(any v) { this._items.push(v); }
    public any pop() {
        if (this._items.length() == 0) { return null; }
        return this._items.pop();
    }
    public int size() { return this._items.length(); }
}

let s = new SafeStack();
s.push("a");
s.push("b");
s.push("c");
out s.pop();   // c
out s.pop();   // b
out s.pop();   // a
out s.pop();   // null (guarded)
out s.size();  // 0

out "── bug 3: power tower within safe range ──";

// Compute powers of 2 up to 2**62 safely
fn int safePow2(int exp) {
    if (exp < 0 || exp > 62) { return -1; }
    return 2 ** exp;
}

out safePow2(0);    // 1
out safePow2(10);   // 1024
out safePow2(20);   // 1048576
out safePow2(30);   // 1073741824
out safePow2(62);   // 4611686018427387904
out safePow2(63);   // -1 (guarded — would overflow)
out safePow2(64);   // -1 (guarded)

// Fibonacci using power: closed-form approximation (integer part)
fn bool isPerfectSquare(int n) {
    let r = sqrt(n * 1.0);
    let ri = round(r);
    return (ri * ri) == (n * 1.0);
}

out isPerfectSquare(1);    // true
out isPerfectSquare(4);    // true
out isPerfectSquare(9);    // true
out isPerfectSquare(10);   // false
out isPerfectSquare(25);   // true

out "── bug 4: typed registry with safe access ──";

// A typed registry that checks key existence before access
class Registry {
    public Registry() { this._data = []; this._keys = []; }
    public void put(string key, int val) {
        let newKeys = [];
        let newData = [];
        let i = 0;
        while (i < this._keys.length()) {
            if (this._keys[i] != key) {
                newKeys.push(this._keys[i]);
                newData.push(this._data[i]);
            }
            i = i + 1;
        }
        newKeys.push(key);
        newData.push(val);
        this._keys = newKeys;
        this._data = newData;
    }
    public bool has(string key) {
        return this._keys.includes(key);
    }
    public any fetch(string key) {
        if (!this.has(key)) { return null; }
        let i = this._keys.indexOf(key);
        return this._data[i];
    }
    public int size() { return this._keys.length(); }
}

let reg = new Registry();
reg.put("score", 100);
reg.put("level", 5);
reg.put("lives", 3);

out reg.size();                // 3
out reg.has("score");          // true
out reg.has("missing");        // false
out reg.fetch("score");        // 100
out reg.fetch("level");        // 5
out reg.fetch("missing");      // null (safely guarded)

reg.put("score", 250);
out reg.fetch("score");        // 250

out "── integration: game loop using all fixed behaviors ──";

// Mini game loop: queue of events, typed stats, power-based scoring
class GameState {
    public GameState() {
        this.events = [];
        this.score  = 0;
        this.level  = 1;
    }
    public void addEvent(string e) { this.events.push(e); }
    public string nextEvent() {
        if (this.events.length() == 0) { return "idle"; }
        return this.events.shift();
    }
    public void applyBonus(int lv) {
        if (lv > 10 || lv < 0) { return; }
        this.score = this.score + (2 ** lv);
    }
    public int getScore() { return this.score; }
}

let game = new GameState();
game.addEvent("start");
game.addEvent("collect");
game.addEvent("collect");
game.addEvent("boss");

out game.nextEvent();   // start
game.applyBonus(3);     // +8
out game.nextEvent();   // collect
game.applyBonus(4);     // +16
out game.nextEvent();   // collect
game.applyBonus(5);     // +32
out game.nextEvent();   // boss
game.applyBonus(10);    // +1024
out game.nextEvent();   // idle (events exhausted — guarded shift)
out game.getScore();    // 8+16+32+1024 = 1080
