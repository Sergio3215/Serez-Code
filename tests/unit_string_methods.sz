// Unit tests for string methods

test("length basic", () => {
    assert("hello".length() == 5, "length 5");
    assert("".length() == 0, "length empty");
    assert("Hola Mundo".length() == 10, "length 10");
});

test("toUpperCase / toLowerCase", () => {
    assert("hello".toUpperCase() == "HELLO", "upper");
    assert("WORLD".toLowerCase() == "world", "lower");
    assert("MiXeD".toUpperCase() == "MIXED", "upper mixed");
    assert("MiXeD".toLowerCase() == "mixed", "lower mixed");
});

test("trim", () => {
    assert("  hello  ".trim() == "hello", "trim spaces");
    assert("hello".trim() == "hello", "trim none");
    assert("  ".trim() == "", "trim all spaces");
    assert("\t hi \n".trim() == "hi", "trim tabs/newlines");
});

test("startsWith / endsWith", () => {
    assert("hello world".startsWith("hello") == true, "startsWith true");
    assert("hello world".startsWith("world") == false, "startsWith false");
    assert("hello world".endsWith("world") == true, "endsWith true");
    assert("hello world".endsWith("hello") == false, "endsWith false");
});

test("indexOf (string)", () => {
    assert("hello world".indexOf("world") == 6, "indexOf found");
    assert("hello world".indexOf("xyz") == -1, "indexOf not found");
    assert("abcabc".indexOf("b") == 1, "indexOf first occurrence");
});

test("charAt / str[i] indexing", () => {
    assert("hello".charAt(0) == "h", "charAt 0");
    assert("hello".charAt(4) == "o", "charAt last");
    assert("hello"[0] == "h", "str[0]");
    assert("hello"[4] == "o", "str[4]");
    assert("hello"[99] == null, "str out-of-bounds null");
});

test("replace — first occurrence only", () => {
    assert("hello world hello".replace("hello", "hi") == "hi world hello", "replace first only");
    assert("aaa".replace("a", "b") == "baa", "replace first of 3");
    assert("no match".replace("xyz", "ABC") == "no match", "replace no match");
});

test("replaceAll — all occurrences", () => {
    assert("hello world hello".replaceAll("hello", "hi") == "hi world hi", "replaceAll all");
    assert("aaa".replaceAll("a", "b") == "bbb", "replaceAll all 3");
    assert("no match".replaceAll("xyz", "ABC") == "no match", "replaceAll no match");
});

test("substring", () => {
    assert("hello".substring(1) == "ello", "substring 1-arg from 1");
    assert("hello".substring(0) == "hello", "substring 1-arg from 0");
    assert("abcde".substring(1, 3) == "bc", "substring 2-arg");
    assert("hello".substring(0, 5) == "hello", "substring full range");
});

test("split", () => {
    let parts = "a,b,c".split(",");
    assert(parts.length() == 3, "split 3 parts");
    assert(parts[0] == "a", "split[0]");
    assert(parts[2] == "c", "split[2]");
    let chars = "abc".split("");
    assert(chars.length() == 3, "split empty sep");
    assert(chars[0] == "a", "split char[0]");
});

test("includes / contains", () => {
    assert("hello world".includes("world") == true, "includes true");
    assert("hello world".includes("xyz") == false, "includes false");
    assert("hello world".contains("hello") == true, "contains true");
    assert("hello world".contains("nope") == false, "contains false");
});

test("toString on primitives", () => {
    assert(42.toString() == "42", "int toString");
    assert(true.toString() == "true", "bool toString");
    assert(3.14.toString() == "3.14", "decimal toString");
});

summary();
