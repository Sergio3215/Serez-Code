// TEST: Arrays tipados, métodos, index access

// Creación con sintaxis tipada
let arr [int] = [1, 2, 3, 4, 5];
out arr;          // [1, 2, 3, 4, 5]
out arr.length();   // 5

// Acceso por índice
out arr[0];   // 1
out arr[4];   // 5

// Mutación por índice
arr[0] = 99;
out arr[0];   // 99

// push / pop
arr.push(10);
out arr;        // [99, 2, 3, 4, 5, 10]
let last = arr.pop();
out last;       // 10
out arr;        // [99, 2, 3, 4, 5]

// shift / unshift
let first = arr.shift();
out first;      // 99
arr.unshift(0);
out arr;        // [0, 2, 3, 4, 5]

// sort (ascendente)
let unsorted [int] = [5, 2, 8, 1, 9];
unsorted.sort();
out unsorted;   // [1, 2, 5, 8, 9]

// map
let strs [string] = ["a", "b", "c"];
let upper = strs.map(s => s.toString());
out upper;   // [a, b, c]

// filter
let nums [int] = [1, 2, 3, 4, 5, 6];
let odds = nums.filter(n => n % 2 != 0);
out odds;    // [1, 3, 5]

// reduce
let sum = nums.reduce(0, (acc, n) => acc + n);
out sum;     // 21

// Array vacío
let empty [int] = [];
out empty.length();   // 0

// Array de strings
let words [string] = ["hello", "world"];
out words[1];   // world

// Array de decimales
let decs [decimal] = [1.1, 2.2, 3.3];
out decs[0];   // 1.1

// Nested map con lambda
let doubled = [10, 20, 30].map(x => x * 2);
out doubled;   // [20, 40, 60]

// Array de bools
let flags [bool] = [true, false, true];
out flags[0];  // true
out flags[1];  // false
