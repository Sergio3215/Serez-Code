// Security unit tests: arithmetic safety — overflow detection, safe edge values

// ── Integer boundary values ───────────────────────────────────────────────────

test("i64::MAX is representable", () => {
    let max = 9223372036854775807;
    assert(max > 0,            "MAX is positive");
    assert(max > 9000000000000000000, "MAX > 9e18");
});

test("i64::MIN is representable", () => {
    // -9223372036854775808 overflows as a literal; derive from MAX via bitwise NOT
    let min_val = ~9223372036854775807;   // ~MAX = MIN (two's complement)
    assert(min_val < 0,   "MIN is negative");
    assert(min_val < -9000000000000000000, "MIN < -9e18");
});

test("zero operations are safe", () => {
    assert(0 + 0 == 0,  "0 + 0");
    assert(0 * 0 == 0,  "0 * 0");
    assert(0 - 0 == 0,  "0 - 0");
    assert(0 / 1 == 0,  "0 / 1");
    assert(0 % 1 == 0,  "0 % 1");
});

// ── Safe division ─────────────────────────────────────────────────────────────

test("integer division truncates toward zero", () => {
    assert(7 / 2 == 3,    "7/2 = 3 (truncated)");
    assert(-7 / 2 == -3,  "-7/2 = -3 (truncated toward 0)");
    assert(7 / -2 == -3,  "7/-2 = -3");
    assert(-7 / -2 == 3,  "-7/-2 = 3");
});

test("modulo result has same sign as dividend (Rust behavior)", () => {
    assert(7 % 3 == 1,    "7 % 3 = 1");
    assert(-7 % 3 == -1,  "-7 % 3 = -1 (dividend sign)");
    assert(7 % -3 == 1,   "7 % -3 = 1");
});

// ── Safe guard: division by zero caught at runtime ────────────────────────────

test("manual zero-check prevents division error", () => {
    fn int safeDivide(int a, int b) {
        if (b == 0) { throw "divide by zero"; }
        return a / b;
    }
    let caught = "";
    try { safeDivide(5, 0); } catch (e) { caught = e; }
    assert(caught == "divide by zero", "caught user-thrown error");
    assert(safeDivide(10, 2) == 5, "normal division still works");
});

// ── Bitwise safety ────────────────────────────────────────────────────────────

test("bitwise NOT (~) on max and min", () => {
    let max = 9223372036854775807;   // i64::MAX
    let min_val = ~max;              // ~MAX = MIN (avoids overflow literal)
    assert(min_val < 0,              "~MAX is negative");
    assert(~min_val == max,          "~~MAX = MAX (double NOT round-trips)");
    assert(~min_val == 9223372036854775807, "~MIN = MAX = 9223372036854775807");
});

test("shift by 0 is identity", () => {
    assert((42 << 0) == 42, "42 << 0 = 42");
    assert((42 >> 0) == 42, "42 >> 0 = 42");
});

test("shift by 63: maximum safe shift", () => {
    // 1 << 63 = i64::MIN (most negative) in two's complement
    let x = 1 << 62;
    assert(x > 0, "1<<62 is still positive");
    // 1 << 63 would be detected as out of range or as i64::MIN
    // We just verify 1<<62 is safe
    assert(x == 4611686018427387904, "1<<62 = 4611686018427387904");
});

test("right shift by 62 on large positive", () => {
    let big = 9223372036854775807;  // MAX
    let r = big >> 62;
    assert(r == 1, "MAX >> 62 = 1 (top bit shifted out)");
});

// ── Power safety ──────────────────────────────────────────────────────────────

test("0 ** 0 = 1 (mathematical convention)", () => {
    assert(0 ** 0 == 1, "0**0 = 1");
});

test("1 to any power = 1", () => {
    assert(1 ** 0   == 1,  "1**0 = 1");
    assert(1 ** 100 == 1,  "1**100 = 1");
    assert(1 ** 1000 == 1, "1**1000 = 1");
});

test("negative base, even power = positive", () => {
    assert((-2) ** 2 == 4,   "(-2)**2 = 4");
    assert((-3) ** 4 == 81,  "(-3)**4 = 81");
});

test("negative base, odd power = negative", () => {
    assert((-2) ** 3 == -8,  "(-2)**3 = -8");
    assert((-3) ** 3 == -27, "(-3)**3 = -27");
});

// ── Decimal arithmetic safety ─────────────────────────────────────────────────

test("decimal division does not produce NaN or infinity for normal values", () => {
    assert(1.0 / 2.0 == 0.5,   "1.0/2.0 = 0.5");
    assert(10.0 / 4.0 == 2.5,  "10.0/4.0 = 2.5");
    assert(0.1 + 0.2 > 0.0,    "0.1 + 0.2 > 0 (not NaN)");
});

test("large decimal powers stay numeric", () => {
    let x = 2.0 ** 32.0;
    assert(x > 0.0,             "2.0**32.0 is positive");
    assert(x == 4294967296.0,   "2.0**32.0 = 4294967296");
});

// ── Safe accumulation ─────────────────────────────────────────────────────────

test("accumulation of 10000 additions stays precise", () => {
    let sum = 0;
    let i = 0;
    while (i < 10000) {
        sum = sum + 1;
        i = i + 1;
    }
    assert(sum == 10000, "10000 additions = 10000");
});

summary();
