// do/while loops
// Tests the do { ... } while (cond) construct added in the improve branch

test("do/while executes body at least once when condition is false", () => {
    let count = 0;
    do {
        count = count + 1;
    } while (false);
    assert(count == 1, "body runs once even when condition is false from the start");
});

test("do/while executes body at least once when condition is initially false (variable)", () => {
    let flag = false;
    let count = 0;
    do {
        count = count + 1;
    } while (flag);
    assert(count == 1, "body runs once when flag is false");
});

test("do/while: basic counting loop", () => {
    let i = 0;
    let sum = 0;
    do {
        i = i + 1;
        sum = sum + i;
    } while (i < 5);
    assert(i == 5,    "loop ran until i == 5");
    assert(sum == 15, "sum of 1..5 = 15");
});

test("do/while: computes factorial via loop", () => {
    let n = 5;
    let result = 1;
    do {
        result = result * n;
        n = n - 1;
    } while (n > 0);
    assert(result == 120, "5! = 120");
});

test("do/while: break exits the loop", () => {
    let i = 0;
    do {
        i = i + 1;
        if (i == 3) { break; }
    } while (i < 100);
    assert(i == 3, "break exits at i == 3");
});

test("do/while: continue skips rest of body, re-checks condition", () => {
    let i = 0;
    let evens = 0;
    do {
        i = i + 1;
        if (i % 2 != 0) { continue; }
        evens = evens + 1;
    } while (i < 8);
    assert(evens == 4, "evens 2,4,6,8 counted = 4");
});

test("do/while: condition evaluated after each body execution", () => {
    let val = 10;
    let iterations = 0;
    do {
        iterations = iterations + 1;
        val = val - 3;
    } while (val > 0);
    assert(iterations == 4, "loop runs 4 times (10,7,4,1 > 0)");
});

test("do/while: collects items into array", () => {
    let arr = [];
    let i = 1;
    do {
        arr.push(i * i);
        i = i + 1;
    } while (i <= 5);
    assert(arr.length() == 5, "collected 5 squares");
    assert(arr[0] == 1,  "arr[0] = 1");
    assert(arr[4] == 25, "arr[4] = 25");
});

test("do/while: single iteration when body sets condition false", () => {
    let x = 5;
    let ran = 0;
    do {
        ran = ran + 1;
        x = x - 5;
    } while (x > 0);
    assert(ran == 1, "only one iteration: x becomes 0 after first body");
});

test("do/while nested inside regular while", () => {
    let outer = 0;
    let total = 0;
    while (outer < 3) {
        outer = outer + 1;
        let inner = 0;
        do {
            inner = inner + 1;
            total = total + 1;
        } while (inner < 2);
    }
    assert(total == 6, "3 outer * 2 inner = 6 total iterations");
});

test("do/while: return from inside do/while exits function", () => {
    fn int findFirst() {
        let i = 0;
        do {
            i = i + 1;
            if (i == 4) { return i; }
        } while (i < 10);
        return -1;
    }
    assert(findFirst() == 4, "return inside do/while returns 4");
});

test("do/while vs while: same result for identical logic", () => {
    let w = 0;
    let wi = 1;
    while (wi <= 10) {
        w = w + wi;
        wi = wi + 1;
    }
    let d = 0;
    let di = 1;
    do {
        d = d + di;
        di = di + 1;
    } while (di <= 10);
    assert(w == d,  "while and do/while produce the same sum");
    assert(w == 55, "sum 1..10 = 55");
});

summary();
