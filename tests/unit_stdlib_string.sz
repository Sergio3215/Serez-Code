// Unit tests: std/string

import "std/string";

test("padStart", () => {
    assert(padStart("7", 3, "0") == "007",   "pad single digit");
    assert(padStart("42", 5, "0") == "00042","pad two digits");
    assert(padStart("hello", 3, "0") == "hello", "no pad needed");
});

test("padEnd", () => {
    assert(padEnd("hi", 5, ".") == "hi...", "pad end");
    assert(padEnd("hello", 3, ".") == "hello", "no pad needed");
});

test("strRepeat", () => {
    assert(strRepeat("ab", 3) == "ababab", "repeat 3");
    assert(strRepeat("x", 0) == "", "repeat 0");
});

test("capitalize", () => {
    assert(capitalize("hello") == "Hello", "capitalize");
    assert(capitalize("WORLD") == "World", "capitalize lowercases rest");
    assert(capitalize("") == "", "empty string");
});

test("isPalindrome", () => {
    assert(isPalindrome("racecar"),  "racecar");
    assert(isPalindrome("madam"),    "madam");
    assert(!isPalindrome("hello"),   "hello is not");
    assert(isPalindrome("A"),        "single char");
});

test("reverseStr", () => {
    assert(reverseStr("abc") == "cba",   "abc reversed");
    assert(reverseStr("") == "",         "empty");
    assert(reverseStr("a") == "a",       "single char");
});

test("words", () => {
    let w = words("  hello   world  ");
    assert(w.length() == 2, "two words");
    assert(w[0] == "hello", "first word");
    assert(w[1] == "world", "second word");
});

test("isDigit and isAlpha", () => {
    assert(isDigit("5"),    "5 is digit");
    assert(!isDigit("a"),   "a is not digit");
    assert(isAlpha("z"),    "z is alpha");
    assert(!isAlpha("3"),   "3 is not alpha");
    assert(isAlphaNumeric("a"), "a is alphanumeric");
    assert(isAlphaNumeric("3"), "3 is alphanumeric");
    assert(!isAlphaNumeric("!"), "! is not alphanumeric");
});

test("titleCase", () => {
    assert(titleCase("the quick brown fox") == "The Quick Brown Fox", "four words");
    assert(titleCase("hello world")         == "Hello World",         "two words");
    assert(titleCase("hello")               == "Hello",               "single word");
    assert(titleCase("UPPER CASE")          == "Upper Case",          "already upper");
});

test("lines", () => {
    let l = lines("a\nb\nc");
    assert(l.length() == 3, "three lines");
    assert(l[0] == "a" && l[1] == "b" && l[2] == "c", "values");
    let single = lines("hello");
    assert(single.length() == 1 && single[0] == "hello", "single line");
});

test("countOccurrences", () => {
    assert(countOccurrences("abcabc", "bc") == 2,             "two non-overlapping");
    assert(countOccurrences("hello world hello", "hello") == 2, "two occurrences");
    assert(countOccurrences("hello", "x") == 0,               "no match");
    assert(countOccurrences("hello", "") == 0,                 "empty sub → 0");
    assert(countOccurrences("aaaa", "aa") == 2,               "non-overlapping aa in aaaa");
    assert(countOccurrences("abc", "abc") == 1,               "full string match");
});

summary();
