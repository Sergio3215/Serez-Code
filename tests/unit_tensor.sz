// Unit tests: Tensor type — Phase 2

test("Tensor constructor with shape and fill", () => {
    let t = new Tensor([3], 0.0);
    assert(t.size() == 3, "size should be 3");
    assert(t.ndim() == 1, "ndim should be 1");
});

test("Tensor shape() returns array", () => {
    let t = new Tensor([2, 3], 1.0);
    let s = t.shape();
    assert(s[0] == 2, "rows should be 2");
    assert(s[1] == 3, "cols should be 3");
});

test("Tensor get and set 1D", () => {
    let t = new Tensor([3], 0.0);
    t.set(1, 42.0);
    assert(t.get(1) == 42.0, "get(1) should be 42.0");
    assert(t.get(0) == 0.0, "get(0) should still be 0.0");
});

test("Tensor get and set 2D", () => {
    let t = new Tensor([2, 2], 0.0);
    t.set(0, 1, 7.0);
    assert(t.get(0, 1) == 7.0, "get(0,1) should be 7.0");
    assert(t.get(1, 0) == 0.0, "get(1,0) should be 0.0");
});

test("Tensor.zeros static", () => {
    let t = Tensor.zeros([2, 3]);
    assert(t.size() == 6, "size should be 6");
    assert(t.sum() == 0.0, "sum of zeros should be 0.0");
});

test("Tensor.ones static", () => {
    let t = Tensor.ones([4]);
    assert(t.size() == 4, "size should be 4");
    assert(t.sum() == 4.0, "sum of ones should be 4.0");
});

test("Tensor.eye identity matrix", () => {
    let t = Tensor.eye(3);
    assert(t.get(0, 0) == 1.0, "diagonal element should be 1");
    assert(t.get(0, 1) == 0.0, "off-diagonal should be 0");
    assert(t.get(2, 2) == 1.0, "last diagonal should be 1");
});

test("Tensor.from 1D array", () => {
    let t = Tensor.from([1, 2, 3, 4]);
    assert(t.size() == 4, "size should be 4");
    assert(t.get(2) == 3.0, "element 2 should be 3.0");
});

test("Tensor.from 2D array", () => {
    let t = Tensor.from([[1, 2], [3, 4]]);
    assert(t.ndim() == 2, "should be 2D");
    assert(t.get(1, 0) == 3.0, "element [1][0] should be 3.0");
});

test("Tensor element-wise add", () => {
    let a = Tensor.from([1, 2, 3]);
    let b = Tensor.from([4, 5, 6]);
    let c = a.add(b);
    assert(c.get(0) == 5.0, "1+4=5");
    assert(c.get(2) == 9.0, "3+6=9");
});

test("Tensor scalar multiply", () => {
    let t = Tensor.from([2, 4, 6]);
    let r = t.mul(3);
    assert(r.get(0) == 6.0, "2*3=6");
    assert(r.get(1) == 12.0, "4*3=12");
});

test("Tensor matmul 2x2", () => {
    let a = Tensor.from([[1, 2], [3, 4]]);
    let b = Tensor.from([[5, 6], [7, 8]]);
    let c = a.matmul(b);
    assert(c.get(0, 0) == 19.0, "[[1,2],[3,4]] x [[5,6],[7,8]] -> [0][0] = 19");
    assert(c.get(1, 1) == 50.0, "[1][1] = 50");
});

test("Tensor dot product 1D", () => {
    let a = Tensor.from([1, 2, 3]);
    let b = Tensor.from([4, 5, 6]);
    let d = a.dot(b);
    assert(d == 32.0, "1*4+2*5+3*6=32");
});

test("Tensor transpose 2D", () => {
    let t = Tensor.from([[1, 2, 3], [4, 5, 6]]);
    let tr = t.transpose();
    let s = tr.shape();
    assert(s[0] == 3, "transposed rows should be 3");
    assert(s[1] == 2, "transposed cols should be 2");
    assert(tr.get(0, 1) == 4.0, "tr[0][1] should be 4");
});

test("Tensor reshape", () => {
    let t = Tensor.from([1, 2, 3, 4, 5, 6]);
    let r = t.reshape([2, 3]);
    assert(r.ndim() == 2, "reshaped to 2D");
    assert(r.get(1, 2) == 6.0, "element [1][2] should be 6");
});

test("Tensor sum, mean, max, min", () => {
    let t = Tensor.from([1, 2, 3, 4, 5]);
    assert(t.sum() == 15.0, "sum should be 15");
    assert(t.mean() == 3.0, "mean should be 3");
    assert(t.max() == 5.0, "max should be 5");
    assert(t.min() == 1.0, "min should be 1");
});

test("Tensor flatten", () => {
    let t = Tensor.from([[1, 2], [3, 4]]);
    let f = t.flatten();
    assert(f.ndim() == 1, "flattened should be 1D");
    assert(f.size() == 4, "size should be 4");
});

test("Tensor fill", () => {
    let t = Tensor.ones([3]);
    let f = t.fill(7.0);
    assert(f.sum() == 21.0, "fill(7)*3 should be 21");
});

test("Tensor toArray 1D", () => {
    let t = Tensor.from([1, 2, 3]);
    let a = t.toArray();
    assert(a[0] == 1.0, "first element should be 1.0");
    assert(a[2] == 3.0, "third element should be 3.0");
});

test("Tensor toArray 2D", () => {
    let t = Tensor.from([[1, 2], [3, 4]]);
    let a = t.toArray();
    assert(a[0][1] == 2.0, "a[0][1] should be 2.0");
    assert(a[1][0] == 3.0, "a[1][0] should be 3.0");
});

test("type_of Tensor", () => {
    let t = Tensor.zeros([2]);
    assert(type_of(t) == "Tensor", "type_of should be Tensor");
});

test("Tensor out-of-bounds index throws", () => {
    let t = Tensor.from([1, 2, 3]);
    let caught = false;
    try {
        let x = t.get(5);
    } catch (e) {
        caught = true;
    }
    assert(caught, "out-of-bounds get should throw");
});

test("Tensor matmul dimension mismatch throws", () => {
    let a = Tensor.from([[1, 2], [3, 4]]);
    let b = Tensor.from([[1, 2, 3]]);
    let caught = false;
    try {
        let c = a.matmul(b);
    } catch (e) {
        caught = true;
    }
    assert(caught, "matmul dimension mismatch should throw");
});

summary();
