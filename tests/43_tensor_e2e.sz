// E2E: Tensor linear algebra — matrix operations end-to-end

// Build a 3x3 identity and verify it acts as identity under matmul
let I = Tensor.eye(3);
let A = Tensor.from([[1, 2, 3], [4, 5, 6], [7, 8, 9]]);
let IA = I.matmul(A);

// IA should equal A
let ok = true;
let r = 0;
while (r < 3) {
    let c = 0;
    while (c < 3) {
        if (IA.get(r, c) != A.get(r, c)) {
            ok = false;
        }
        c += 1;
    }
    r += 1;
}

// Verify dot product
let u = Tensor.from([1, 0, 0]);
let v = Tensor.from([0, 1, 0]);
let dot_perp = u.dot(v);
let u2 = Tensor.from([3, 4]);
let dot_self = u2.dot(u2);

// Transpose sanity: (A^T)^T == A
let AT  = A.transpose();
let ATT = AT.transpose();
let transpose_ok = ATT.get(1, 2) == A.get(1, 2);

out ok && dot_perp == 0.0 && dot_self == 25.0 && transpose_ok;
