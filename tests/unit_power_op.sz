// Power operator ** (exponentiation)
// Tests the ** operator added in the improve branch

test("integer ** integer: basic cases", () => {
    assert(2 ** 0  == 1,    "2 ** 0 = 1");
    assert(2 ** 1  == 2,    "2 ** 1 = 2");
    assert(2 ** 10 == 1024, "2 ** 10 = 1024");
    assert(3 ** 3  == 27,   "3 ** 3 = 27");
    assert(10 ** 3 == 1000, "10 ** 3 = 1000");
});

test("integer ** 0 always yields 1", () => {
    assert(0 ** 0  == 1, "0 ** 0 = 1");
    assert(5 ** 0  == 1, "5 ** 0 = 1");
    assert(99 ** 0 == 1, "99 ** 0 = 1");
});

test("1 ** n always yields 1", () => {
    assert(1 ** 0  == 1, "1 ** 0 = 1");
    assert(1 ** 1  == 1, "1 ** 1 = 1");
    assert(1 ** 99 == 1, "1 ** 99 = 1");
});

test("integer ** negative: yields decimal", () => {
    let r = 2 ** -1;
    assert(r == 0.5,  "2 ** -1 = 0.5 (decimal)");
    let r2 = 4 ** -2;
    assert(r2 == 0.0625, "4 ** -2 = 0.0625");
});

test("decimal ** decimal", () => {
    let r = 4.0 ** 0.5;
    assert(r == 2.0, "4.0 ** 0.5 = 2.0 (square root)");
    let r2 = 8.0 ** (1.0 / 3.0);
    assert(r2 > 1.99 && r2 < 2.01, "8.0 ** (1/3) ≈ 2.0 (cube root)");
});

test("decimal ** integer", () => {
    assert(2.5 ** 2 == 6.25, "2.5 ** 2 = 6.25");
    assert(1.5 ** 3 == 3.375, "1.5 ** 3 = 3.375");
});

test("integer ** decimal", () => {
    let r = 9 ** 0.5;
    assert(r == 3.0, "9 ** 0.5 = 3.0");
});

test("** in expression context", () => {
    assert(2 ** 3 + 1 == 9,  "2 ** 3 + 1 = 9 (** before +)");
    assert(2 + 2 ** 3 == 10, "2 + 2 ** 3 = 10 (** before +)");
    assert((2 + 2) ** 2 == 16, "(2+2) ** 2 = 16");
});

test("** in recursive function (manual pow)", () => {
    fn int ipow(int base, int exp) {
        if (exp == 0) { return 1; }
        return base * ipow(base, exp - 1);
    }
    assert(ipow(2, 8) == 2 ** 8, "recursive ipow matches ** for 2^8");
    assert(ipow(3, 4) == 3 ** 4, "recursive ipow matches ** for 3^4");
});

test("** is right-associative (B-79)", () => {
    // Math/Python convention: 2 ** 3 ** 2 = 2 ** (3 ** 2) = 2 ** 9 = 512
    assert(2 ** 3 ** 2 == 512, "2**3**2 = 512 (right-assoc)");
    assert(2 ** 2 ** 3 == 256, "2**2**3 = 2**8 = 256");
    assert((2 ** 3) ** 2 == 64, "explicit grouping still forces left");
    assert(2 ** 3 * 4 == 32, "** binds tighter than * → (2**3)*4");
    assert(2 ** 3 + 1 == 9, "** binds tighter than +");
});

summary();
