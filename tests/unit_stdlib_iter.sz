// Unit tests: std/iter

import "std/iter";

test("range ascending", () => {
    let r = range(0, 5, 1);
    assert(r.length() == 5, "length 5");
    assert(r[0] == 0 && r[4] == 4, "values 0..4");
});

test("range with step", () => {
    let r = range(0, 10, 2);
    assert(r.length() == 5, "length 5");
    assert(r[2] == 4, "third element is 4");
});

test("range descending", () => {
    let r = range(5, 0, -1);
    assert(r.length() == 5, "length 5");
    assert(r[0] == 5 && r[4] == 1, "5 down to 1");
});

test("zip two arrays", () => {
    let z = zip([1,2,3], ["a","b","c"]);
    assert(z.length() == 3, "3 pairs");
    assert(z[0][0] == 1 && z[0][1] == "a", "first pair");
});

test("zip truncates to shorter", () => {
    let z = zip([1,2,3,4], ["x","y"]);
    assert(z.length() == 2, "truncated to 2");
});

test("enumerate", () => {
    let e = enumerate(["a","b","c"]);
    assert(e[0][0] == 0 && e[0][1] == "a", "index 0");
    assert(e[2][0] == 2 && e[2][1] == "c", "index 2");
});

test("flatten one level", () => {
    let f = flatten([[1,2],[3,4],[5]]);
    assert(f.length() == 5, "5 elements");
    assert(f[0] == 1 && f[4] == 5, "values correct");
});

test("take and skip", () => {
    let arr = [1,2,3,4,5];
    assert(take(arr, 3).length() == 3, "take 3");
    assert(skip(arr, 2).length() == 3, "skip 2 → 3 remain");
    assert(skip(arr, 2)[0] == 3, "first after skip is 3");
});

test("chunk", () => {
    let c = chunk([1,2,3,4,5], 2);
    assert(c.length() == 3, "3 chunks");
    assert(c[0].length() == 2, "first chunk size 2");
    assert(c[2].length() == 1, "last chunk size 1");
});

test("first and last", () => {
    assert(first([10,20,30]) == 10, "first");
    assert(last([10,20,30]) == 30,  "last");
    assert(first([]) == null, "first of empty");
    assert(last([])  == null, "last of empty");
});

test("all and any_match", () => {
    let isPos = x => x > 0;
    assert(all([1,2,3], isPos),  "all positive");
    assert(!all([1,-1,3], isPos),"not all positive");
    assert(any_match([1,-1,3], isPos), "some positive");
    assert(!any_match([-1,-2], isPos), "none positive");
});

test("count", () => {
    let isEven = x => x % 2 == 0;
    assert(count([1,2,3,4,5,6], isEven) == 3, "3 evens");
    assert(count([1,3,5], isEven) == 0, "0 evens");
    assert(count([], isEven) == 0, "empty array");
});

test("take and skip edge cases", () => {
    let arr = [1,2,3];
    assert(take(arr, 10).length() == 3, "take more than length returns all");
    assert(take(arr, 0).length() == 0,  "take 0 returns empty");
    assert(skip(arr, 3).length() == 0,  "skip all returns empty");
    assert(skip(arr, 10).length() == 0, "skip beyond length returns empty");
    assert(skip(arr, 0).length() == 3,  "skip 0 returns all");
});

test("flatten with mixed items", () => {
    let f = flatten([[1,2], 3, [4,5]]);
    assert(f.length() == 5, "5 elements");
    assert(f[2] == 3, "bare 3 stays");
});

test("all and any_match on empty", () => {
    let alwaysFalse = x => false;
    assert(all([], alwaysFalse),        "all([]) is vacuously true");
    assert(!any_match([], alwaysFalse), "any_match([]) is false");
});

test("range descending with step -2", () => {
    let r = range(10, 0, -2);
    assert(r.length() == 5, "5 elements");
    assert(r[0] == 10 && r[4] == 2, "10 down to 2 step -2");
});

summary();
