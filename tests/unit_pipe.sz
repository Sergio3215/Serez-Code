// Unit tests: pipe operator |>

fn double(int n) { return n * 2; }
fn inc(int n)    { return n + 1; }
fn square(int n) { return n * n; }

test("pipe — single function call", () => {
    assert(5 |> double == 10, "double");
    assert(3 |> square == 9, "square");
});

test("pipe — chaining", () => {
    assert(5 |> double |> inc == 11, "double then inc");
    assert(2 |> inc |> double == 6, "inc then double");
    assert(3 |> double |> double == 12, "double twice");
});

test("pipe — lambda on right", () => {
    assert(7 |> n => n * n == 49, "lambda square");
    assert(10 |> n => n - 3 == 7, "lambda subtract");
});

test("pipe — string operations", () => {
    let s = "  hello  " |> str => str.trim();
    assert(s == "hello", "trim");
    let upper = "world" |> str => str.upper();
    assert(upper == "WORLD", "upper");
});

test("pipe — array operations", () => {
    let arr = [1, 2, 3, 4, 5] |> a => a.filter(x => x > 3);
    assert(arr.length() == 2, "filter length");
    assert(arr[0] == 4, "filter[0]");
    assert(arr[1] == 5, "filter[1]");
});

test("pipe — array map+sum pipeline", () => {
    fn sum(any a) { return a.reduce(0, (acc, x) => acc + x); }
    let result = [1, 2, 3] |> a => a.map(x => x * 2) |> sum;
    assert(result == 12, "2+4+6=12");
});

test("pipe — associativity (left to right)", () => {
    // 5 |> double |> inc = (5 |> double) |> inc = 10 |> inc = 11
    assert(5 |> double |> inc == 11, "left-associative");
    // NOT 5 |> (double |> inc) which would be different
});

test("pipe — with match expression result", () => {
    fn classify(int n) {
        return match n { n if n > 0 => "pos", 0 => "zero", _ => "neg" };
    }
    assert(-1 |> classify == "neg", "neg");
    assert(0  |> classify == "zero", "zero");
    assert(1  |> classify == "pos", "pos");
});

summary();
