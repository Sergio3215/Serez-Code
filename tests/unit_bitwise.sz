// Unit tests: bitwise operators &, |, ^, ~, <<, >> and power **

test("bitwise AND (&)", () => {
    assert((0b1100 & 0b1010) == 8,  "12 & 10 = 8");
    assert((255 & 0) == 0,          "255 & 0 = 0");
    assert((255 & 255) == 255,      "255 & 255 = 255");
    assert((7 & 3) == 3,            "7 & 3 = 3");
    assert((5 & 6) == 4,            "5 & 6 = 4");
});

test("bitwise OR (|)", () => {
    assert((0b1100 | 0b1010) == 14, "12 | 10 = 14");
    assert((0 | 0) == 0,            "0 | 0 = 0");
    assert((5 | 3) == 7,            "5 | 3 = 7");
    assert((255 | 0) == 255,        "255 | 0 = 255");
});

test("bitwise XOR (^)", () => {
    assert((0b1100 ^ 0b1010) == 6,  "12 ^ 10 = 6");
    assert((5 ^ 5) == 0,            "5 ^ 5 = 0 (same ^ same)");
    assert((5 ^ 0) == 5,            "5 ^ 0 = 5");
    assert((7 ^ 3) == 4,            "7 ^ 3 = 4");
    assert((0 ^ 0) == 0,            "0 ^ 0 = 0");
});

test("bitwise NOT (~)", () => {
    assert(~0 == -1,                "~0 = -1");
    assert(~(-1) == 0,              "~(-1) = 0");
    assert(~5 == -6,                "~5 = -6 (two's complement)");
    assert(~(-5) == 4,              "~(-5) = 4");
    assert(~~42 == 42,              "double ~ is identity");
});

test("left shift (<<)", () => {
    assert((1 << 0) == 1,           "1 << 0 = 1");
    assert((1 << 1) == 2,           "1 << 1 = 2");
    assert((1 << 4) == 16,          "1 << 4 = 16");
    assert((3 << 2) == 12,          "3 << 2 = 12");
    assert((5 << 3) == 40,          "5 << 3 = 40");
});

test("right shift (>>)", () => {
    assert((16 >> 4) == 1,          "16 >> 4 = 1");
    assert((8 >> 1) == 4,           "8 >> 1 = 4");
    assert((100 >> 2) == 25,        "100 >> 2 = 25");
    assert((1 >> 0) == 1,           "1 >> 0 = 1");
    assert((7 >> 1) == 3,           "7 >> 1 = 3 (floor)");
});

test("power (**) integer base", () => {
    assert((2 ** 0) == 1,           "2**0 = 1");
    assert((2 ** 1) == 2,           "2**1 = 2");
    assert((2 ** 10) == 1024,       "2**10 = 1024");
    assert((3 ** 3) == 27,          "3**3 = 27");
    assert((10 ** 3) == 1000,       "10**3 = 1000");
    assert((0 ** 5) == 0,           "0**5 = 0");
    assert((1 ** 100) == 1,         "1**100 = 1");
});

test("power (**) decimal base and exponent", () => {
    assert((4.0 ** 0.5) == 2.0,     "4.0**0.5 = 2.0 (sqrt)");
    assert((2.0 ** 3.0) == 8.0,     "2.0**3.0 = 8.0");
    assert((9.0 ** 0.5) == 3.0,     "9.0**0.5 = 3.0 (sqrt)");
});

test("power precedence: ** binds tighter than * and +", () => {
    assert(2 + 3 ** 2 == 11,        "2 + 3**2 = 11, not 25");
    assert(2 * 3 ** 2 == 18,        "2 * 3**2 = 18, not 36");
    assert(10 - 2 ** 3 == 2,        "10 - 2**3 = 2");
});

test("bitwise combined with arithmetic", () => {
    assert((5 & 3) + 1 == 2,        "(5&3)+1 = 2");
    assert((3 | 4) * 2 == 14,       "(3|4)*2 = 14");
    assert((1 << 3) - 1 == 7,       "(1<<3)-1 = 7");
});

test("numeric separators in literals", () => {
    let million = 1_000_000;
    assert(million == 1000000,       "1_000_000 = 1000000");
    let big = 1_234_567;
    assert(big == 1234567,           "1_234_567 = 1234567");
    let small = 1_0;
    assert(small == 10,              "1_0 = 10");
});

summary();
